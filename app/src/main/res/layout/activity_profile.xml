<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F1F3F6">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#2874F0" android:padding="20dp" android:orientation="vertical" android:gravity="center">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👨‍💼" android:textSize="60sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pro User" android:textColor="#FFFFFF" android:textSize="24sp" android:textStyle="bold" android:layout_marginTop="10dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="prouser@zipcart.com" android:textColor="#E0E0E0" android:textSize="14sp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="10dp">
        <Button android:layout_width="match_parent" android:layout_height="60dp" android:text="📦 My Orders" android:textAlignment="viewStart" android:backgroundTint="#FFFFFF" android:textColor="#000000" android:paddingLeft="20dp"/>
        <Button android:layout_width="match_parent" android:layout_height="60dp" android:text="❤️ Wishlist" android:textAlignment="viewStart" android:backgroundTint="#FFFFFF" android:textColor="#000000" android:paddingLeft="20dp" android:layout_marginTop="2dp"/>
        <Button android:layout_width="match_parent" android:layout_height="60dp" android:text="⚙️ Settings" android:textAlignment="viewStart" android:backgroundTint="#FFFFFF" android:textColor="#000000" android:paddingLeft="20dp" android:layout_marginTop="2dp"/>
        <Button android:id="@+id/btn_logout" android:layout_width="match_parent" android:layout_height="60dp" android:text="🚪 Logout" android:textAlignment="viewStart" android:backgroundTint="#FFFFFF" android:textColor="#FF3B30" android:paddingLeft="20dp" android:layout_marginTop="10dp"/>
    </LinearLayout>
</LinearLayout>
